# =============================================================================
# Reliance Finance - Variables d'environnement PRODUCTION
# =============================================================================
# Sur le VPS, ce fichier vit a `/opt/reliance-finance/.env.production`
# avec chmod 600 et owner deploy user.
#
# NE JAMAIS commiter de vraies valeurs. NE JAMAIS partager.
# =============================================================================

# -----------------------------------------------------------------------------
# Domaine + URL
# -----------------------------------------------------------------------------
APP_DOMAIN=finances.rwa-core.com
NEXT_PUBLIC_APP_URL=https://finances.rwa-core.com

# -----------------------------------------------------------------------------
# Image Docker
# -----------------------------------------------------------------------------
# Tag deploye (latest, ou un SHA commit pour rollback)
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=reliance
# Generer : openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_strong_random_at_least_24_chars
POSTGRES_DB=reliance_finance

# -----------------------------------------------------------------------------
# MinIO (object storage S3-compatible)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=reliance-prod
# Generer : openssl rand -base64 32
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_random_at_least_32_chars

# -----------------------------------------------------------------------------
# Authentification
# -----------------------------------------------------------------------------
# Generer : openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32
AUTH_SESSION_MAX_AGE_SECONDS=900

# -----------------------------------------------------------------------------
# Email (Hostinger SMTP - subscription "Starter Business Email")
# -----------------------------------------------------------------------------
EMAIL_SERVER_HOST=smtp.hostinger.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=no-reply@reliancewestafrica.com
EMAIL_SERVER_PASSWORD=CHANGE_ME_email_password_from_hostinger
EMAIL_FROM="Reliance Finance <no-reply@reliancewestafrica.com>"

# -----------------------------------------------------------------------------
# Anti-fraude / conformite
# -----------------------------------------------------------------------------
ANTI_FRAUD_RIB_QUARANTINE_HOURS=24

# -----------------------------------------------------------------------------
# Cron interne (container reliance-cron appelle les endpoints /api/cron/*)
# -----------------------------------------------------------------------------
# Generer : openssl rand -hex 32
CRON_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
