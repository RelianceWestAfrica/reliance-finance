{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Reliance Node Package",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"]
}
