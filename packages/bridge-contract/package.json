{
  "name": "@reliancewestafrica/bridge-contract",
  "version": "0.1.0",
  "private": false,
  "license": "UNLICENSED",
  "description": "Contrat de donnees generique du pont financier inter-plateformes RWA (FinancialIntent + HMAC). Reutilisable par les apps sources (chantier, logistique, immobilier, RH).",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/RelianceWestAfrica/reliance-finance.git",
    "directory": "packages/bridge-contract"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@reliance-finance/tsconfig": "workspace:*",
    "@types/node": "^22.9.0",
    "typescript": "^5.7.3"
  }
}
