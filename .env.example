# =============================================================================
# Reliance Finance - Variables d'environnement (exemple)
# =============================================================================
# Copier ce fichier vers .env.local et remplir les valeurs.
# NE JAMAIS COMMITER .env.local. Les secrets de production sont gérés par
# Hostinger (variables VPS) ou un coffre de secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Reliance Finance"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Fuseau horaire d'affichage par défaut (utilisateur peut surcharger)
NEXT_PUBLIC_DEFAULT_TIMEZONE=Africa/Lome

# Devise d'affichage par défaut (XOF, XAF, USD, EUR)
NEXT_PUBLIC_DEFAULT_CURRENCY=XOF

# -----------------------------------------------------------------------------
# Base de données PostgreSQL
# -----------------------------------------------------------------------------
# Valeur par défaut alignée avec docker-compose.yml (service postgres)
DATABASE_URL=postgresql://reliance:reliance_dev@localhost:5432/reliance_finance?schema=public

# Connexion poolée (production : pgBouncer / Hostinger Postgres)
DATABASE_URL_POOLED=

# -----------------------------------------------------------------------------
# Authentification (NextAuth v5 / Auth.js)
# -----------------------------------------------------------------------------
# Génerer avec : openssl rand -base64 32
AUTH_SECRET=changeme_generer_avec_openssl_rand_base64_32

# Trust hôte (laisser true en dev local derrière proxy)
AUTH_TRUST_HOST=true

# Durée de session JWT (15 minutes en prod, plus long en dev)
AUTH_SESSION_MAX_AGE_SECONDS=900

# -----------------------------------------------------------------------------
# Email (Magic Link + notifications)
# -----------------------------------------------------------------------------
# Dev : Mailhog (docker-compose) — SMTP sans auth sur localhost:1025
# Prod : SMTP relai (ex: Hostinger Email, Postmark, SendGrid)
EMAIL_SERVER_HOST=localhost
EMAIL_SERVER_PORT=1025
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM="Reliance Finance <no-reply@reliancewestafrica.com>"

# -----------------------------------------------------------------------------
# Stockage objets (MinIO en dev, S3-compatible en prod)
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=reliance
S3_SECRET_ACCESS_KEY=reliance_dev_minio
S3_BUCKET=reliance-finance-attachments
S3_FORCE_PATH_STYLE=true

# -----------------------------------------------------------------------------
# Sécurité
# -----------------------------------------------------------------------------
# Argon2id - paramètres (production : augmenter memory et timeCost)
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# Rate limiting (req/min par IP sur endpoints sensibles)
RATE_LIMIT_PAYMENT_PER_MIN=5
RATE_LIMIT_BANK_ACCOUNT_CHANGE_PER_MIN=5

# Délai de carence anti-fraude RIB (heures avant qu'un nouveau RIB soit utilisable)
ANTI_FRAUD_RIB_QUARANTINE_HOURS=24

# -----------------------------------------------------------------------------
# Audit & conformité
# -----------------------------------------------------------------------------
# Politique de conservation (10 ans par défaut, conforme cadre normatif §9)
AUDIT_RETENTION_YEARS=10
ARCHIVE_RETENTION_YEARS=10

# -----------------------------------------------------------------------------
# Intégrations (P1+ — non utilisées par le squelette)
# -----------------------------------------------------------------------------
ERP_WEBHOOK_URL=
ERP_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Observabilité (P1+)
# -----------------------------------------------------------------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
