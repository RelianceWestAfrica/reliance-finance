# Reliance Finance - Web app (.env.example)
#
# Copiez ce fichier vers apps/web/.env.local et completez les valeurs.
# La plupart des variables sont aussi lues depuis le .env.local racine via Turbo.

# Generer avec : openssl rand -base64 32
AUTH_SECRET=
AUTH_TRUST_HOST=true
AUTH_SESSION_MAX_AGE_SECONDS=900

# DB (alignee avec docker-compose.yml par defaut)
DATABASE_URL=postgresql://reliance:reliance_dev@localhost:5432/reliance_finance?schema=public

# Email - Mailhog en dev (docker-compose)
EMAIL_SERVER_HOST=localhost
EMAIL_SERVER_PORT=1025
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM="Reliance Finance <no-reply@reliancewestafrica.com>"
